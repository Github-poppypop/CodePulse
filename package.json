{
  "name": "codepulse",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous code improvement engine — point it at a repo, it finds bugs, fixes them, ships PRs, and learns.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --minify",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "db:generate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@fastify/env": "^7.0.0",
    "@google/generative-ai": "^0.21.0",
    "@octokit/rest": "^21.0.0",
    "@octokit/webhooks": "^13.0.0",
    "@prisma/client": "^6.0.0",
    "@types/diff": "^6.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "bullmq": "^5.24.0",
    "diff": "^7.0.0",
    "dotenv": "^16.4.0",
    "envalid": "^8.0.0",
    "eslint": "^9.0.0",
    "execa": "^9.4.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "ioredis": "^5.4.0",
    "openai": "^6.44.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.1.9",
    "zapatos": "^6.6.1",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.5.4"
  },
  "devDependencies": {
    "prettier": "^3.8.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
