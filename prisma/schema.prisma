generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Repository {
  id          String   @id @default(cuid())
  name        String
  owner       String
  url         String   @unique
  branch      String   @default("main")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  runs        Run[]
  findings    Finding[]
}

model Run {
  id            String       @id @default(cuid())
  repositoryId  String
  repository    Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  status        RunStatus    @default(PENDING)
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  trigger       String
  commitSha     String?
  branch        String?
  findings      Finding[]
  fixes         Fix[]
  telemetry     TelemetryEvent[]
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model Finding {
  id            String         @id @default(cuid())
  repositoryId  String
  repository    Repository     @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  runId         String?
  run           Run?           @relation(fields: [runId], references: [id], onDelete: SetNull)
  category      FindingCategory
  severity      Severity
  title         String
  description   String
  filePath      String?
  lineStart     Int?
  lineEnd       Int?
  codeSnippet   String?
  source        String         @default("sensor")
  metadata      Json?
  createdAt     DateTime       @default(now())
  fixes         Fix[]
}

enum FindingCategory {
  BUG
  PERFORMANCE
  SECURITY
  STYLE
  REFACTOR
  TEST
  DOCUMENTATION
  TYPE_SAFETY
  DEPENDENCY
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

model Fix {
  id            String     @id @default(cuid())
  findingId     String
  finding       Finding    @relation(fields: [findingId], references: [id], onDelete: Cascade)
  runId         String?
  run           Run?       @relation(fields: [runId], references: [id], onDelete: SetNull)
  status        FixStatus  @default(PROPOSED)
  description   String
  diff          String?
  appliedAt     DateTime?
  validatedAt   DateTime?
  validation    ValidationResult?
  createdAt     DateTime   @default(now())
}

enum FixStatus {
  PROPOSED
  APPROVED
  APPLIED
  REJECTED
  FAILED
}

model ValidationResult {
  id            String   @id @default(cuid())
  fixId         String   @unique
  fix           Fix      @relation(fields: [fixId], references: [id], onDelete: Cascade)
  passed        Boolean
  testsPassed   Boolean
  typecheckPassed Boolean
  lintPassed    Boolean
  buildPassed   Boolean
  output        String?
  createdAt     DateTime @default(now())
}

model TelemetryEvent {
  id          String   @id @default(cuid())
  runId       String
  run         Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  type        String
  payload     Json?
  createdAt   DateTime @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AutonomyPolicy {
  id          String          @id @default(cuid())
  name        String          @unique
  level       AutonomyLevel   @default(MANUAL)
  rules       Json            // Policy rules as JSON
  enabled     Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum AutonomyLevel {
  MANUAL
  ASSISTED
  SEMI_AUTONOMOUS
  FULLY_AUTONOMOUS
}