generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AnalysisRun {
  id          String   @id @default(uuid())
  repo        String
  branch      String
  status      String
  findingsJson String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FixRecord {
  id           String   @id @default(uuid())
  analysisRunId String
  patchSummary String
  status       String
  createdAt    DateTime @default(now())
}
